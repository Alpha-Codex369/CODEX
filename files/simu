#!/bin/bash

WIDTH=""
TEXT=""

while [[ "$#" -gt 0 ]]; do
    case $1 in
        -w) WIDTH="$2"; shift 2 ;;
        *) 
            if [ -z "$TEXT" ]; then
                TEXT="$1"
            else
                TEXT="$TEXT $1"
            fi
            shift 
            ;;
    esac
done

if [ -z "$TEXT" ]; then
    read -r TEXT
fi

TEXT=$(echo "$TEXT" | tr 'a-z' 'A-Z')

# Awk Engine
awk -v text="$TEXT" -v width="$WIDTH" '
BEGIN {
    alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890?,;:-$=+%#?)(/"
    split(alphabet, chars, "")
    char_idx = 1
    line_idx = 1
    for(i=1; i<=6; i++) map[" ", i] = "      "
}
{
    gsub(/\r/, "", $0)
    if ($0 == "") {
        if (line_idx > 1) {
            char_idx++
            line_idx = 1
        }
    } else {
        if (char_idx <= length(chars)) {
            char = chars[char_idx]
            map[char, line_idx] = $0
            line_idx++
        }
    }
}
END {
    split(text, tchars, "")
    for(line=1; line<=6; line++) {
        out = ""
        for(i=1; i<=length(tchars); i++) {
            c = tchars[i]
            if ((c SUBSEP line) in map) {
                out = out map[c, line]
            } else {
                out = out map[" ", line]
            }
        }

        if (width != "" && width > length(out)) {
            pad = int((width - length(out)) / 2)
            padding = ""
            for(p=1; p<=pad; p++) padding = padding " "
            print padding out
        } else {
            print out
        }
    }
