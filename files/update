}

ask() {
    clear
    echo
    anim_line "		       ${g}Cute-Simu...♡"
    anim_line "${c}              (\_/)"
    anim_line "              (${p}♡ω♡${c})"
    anim_line "             ⊂(___)づ ᯓᡣ𐭩"
    echo
    anim_line " ${C} ${y}Do you want to Update Codex banner?${n}"
    anim_line " ${A} ${g}Type ${y}'y'${g} or ${y}'yes'${g} to continue, otherwise cancel.${c}"
    echo
    read -p "[+]──[Select Option]────► " choice

    choice=$(echo "$choice" | tr '[:upper:]' '[:lower:]')

    if [[ "$choice" == "y" || "$choice" == "yes" ]]; then
        echo -e "\n ${A} ${c}Process confirmed! Starting removal...${n}"
        sleep 1.0
        clear
    else
        echo -e "\n ${E} ${r}Process cancelled by user.${n}"
        echo -e " ${C} ${y}Exiting... ${g}[${n}${HOST}${g}]${n}"
        echo
        exit 1
    fi
}

